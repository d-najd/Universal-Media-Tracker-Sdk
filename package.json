{
  "name": "@d-najd/universal-media-tracker-sdk",
  "version": "0.1.5",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc"
  },
  "exports": {
    "./Plugin": {
      "types": "./dist/Plugin.d.ts",
      "import": "./dist/Plugin.js"
    },
    ".": {
      "types": "./dist/Plugin.d.ts",
      "default": "./dist/Plugin.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*"
    },
    "./**/*": {
      "types": "./dist/**/*.d.ts",
      "default": "./dist/**/*"
    }
  },
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
